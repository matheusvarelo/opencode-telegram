TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: comma-separated list of allowed Telegram chat IDs.
# If set, messages from other chats are silently ignored.
# ALLOWED_CHAT_IDS=123456789,-100987654321

# Optional: path to opencode binary (default: ~/.opencode/bin/opencode)
# OPENCODE_BIN=/home/user/.opencode/bin/opencode

# Optional: working directory for opencode sessions (default: project root)
# OPENCODE_WORK_DIR=/home/user/projects

# Optional: model override (format: provider/model)
# OPENCODE_MODEL=anthropic/claude-sonnet-4-20250514
